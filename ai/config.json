{
    "stream": {
        "url": "0",
        "protocol": "rtsp",
        "fallback_url": "0",
        "resolution": [
            1920,
            1080
        ],
        "target_fps": 30,
        "buffer_size": 2,
        "reconnect_delay_sec": 3,
        "max_reconnect_attempts": 10
    },
    "detector": {
        "model": "yolov8n.pt",
        "model_path": "models/yolov8n.pt",
        "confidence_threshold": 0.5,
        "iou_threshold": 0.45,
        "device": "auto",
        "classes": [
            0
        ],
        "imgsz": 640
    },
    "tracker": {
        "tracker_type": "bytetrack",
        "track_high_thresh": 0.3,
        "track_low_thresh": 0.05,
        "new_track_thresh": 0.3,
        "track_buffer": 30,
        "match_thresh": 0.8
    },
    "zones": {
        "config_file": "zones_config.json",
        "default_zone_type": "Normal",
        "restricted_alert_cooldown_sec": 5,
        "overlay_alpha": 0.3,
        "colors": {
            "Normal": [
                0,
                255,
                0
            ],
            "Restricted": [
                0,
                0,
                255
            ]
        }
    },
    "lstm": {
        "model_path": "models/lstm_classifier.pth",
        "sequence_length": 15,
        "hidden_size": 256,
        "num_layers": 2,
        "num_classes": 7,
        "feature_dim": 8,
        "class_names": [
            "Walking",
            "Running",
            "Loitering",
            "Fall",
            "Lying_Still",
            "Fighting",
            "Panic"
        ]
    },
    "action_postprocess": {
        "default_threshold": 0.5,
        "class_thresholds": {
            "Walking": 0.45,
            "Running": 0.5,
            "Loitering": 0.45,
            "Fall": 0.72,
            "Lying_Still": 0.72,
            "Fighting": 0.82,
            "Panic": 0.70
        },
        "default_stable_windows": 1,
        "stable_windows": {
            "Fall": 2,
            "Lying_Still": 3,
            "Fighting": 4,
            "Panic": 3
        },
        "smoothing_alpha": 0.6,
        "safe_fallback_label": "Loitering",
        "transition_release_windows": 2,
        "idle_reset_windows": 4,
        "fighting": {
            "min_person_count": 2,
            "min_confidence": 0.78,
            "min_speed_norm": 0.015,
            "min_partner_speed_norm": 0.01,
            "max_center_distance_norm": 0.18,
            "min_iou": 0.01
        },
        "panic": {
            "min_person_count": 2,
            "min_confidence": 0.68,
            "min_speed_norm": 0.008,
            "max_center_distance_norm": 0.35
        }
    },
    "event_trigger": {
        "confidence_high": 0.85,
        "confidence_medium": 0.70,
        "alert_cooldown_sec": 5,
        "health_score_init": 100,
        "crime_score_init": 0,
        "health_emergency_threshold": 30,
        "crime_emergency_threshold": 70,
        "score_deltas": {
            "Fall": {
                "health": -30,
                "crime": 0
            },
            "Lying_Still": {
                "health": -20,
                "crime": 0
            },
            "Fighting": {
                "health": -10,
                "crime": 40
            },
            "Panic": {
                "health": -15,
                "crime": 5
            },
            "Zone_Violation": {
                "health": 0,
                "crime": 20
            },
            "Crowd_Surge": {
                "health": -5,
                "crime": 10
            }
        }
    },
    "backend_bridge": {
        "enabled": true,
        "api_url": "http://localhost:5000/api/detect",
        "state_dir": "data/backend_bridge",
        "source": "AI_CAMERA",
        "default_zone_id": "A",
        "event_cooldown_sec": 12,
        "action_event_map": {
            "Fall": "FALL",
            "Lying_Still": "PANIC",
            "Fighting": "AGGRESSION",
            "Panic": "PANIC"
        }
    },
    "action_frame_classifier": {
        "enabled": true,
        "model_path": "models/action_fighting_vs_normal_best.pt",
        "positive_class": "fighting",
        "positive_display_label": "Fighting",
        "negative_display_label": "Normal",
        "confidence_threshold": 0.85,
        "run_every_n_frames": 3,
        "min_persons_for_fighting": 2
    },
    "display": {
        "window_name": "STSMIRS Live Feed",
        "show_fps": true,
        "show_zones": true,
        "show_scores": true,
        "show_alerts": true,
        "alert_display_duration_sec": 5,
        "emergency_flash_duration_sec": 5,
        "font_scale": 0.6,
        "box_thickness": 2,
        "colors": {
            "normal_box": [
                0,
                255,
                0
            ],
            "alert_box": [
                0,
                0,
                255
            ],
            "text": [
                255,
                255,
                255
            ],
            "alert_banner": [
                0,
                0,
                200
            ],
            "emergency_banner": [
                0,
                0,
                255
            ]
        }
    },
    "face_recognition": {
        "enrollment_dir": "project_videos/faces",
        "model": "hog",
        "tolerance": 0.8,
        "yolo_cls_model_path": "models/yolo_cls_faces_best.pt",
        "yolo_cls_enabled": false,
        "yolo_cls_confidence_threshold": 0.9,
        "yolo_cls_required_votes": 3,
        "opencv_enabled": false,
        "video_sample_interval_sec": 1.0,
        "max_video_samples_per_person": 5,
        "max_image_samples_per_person": 24,
        "opencv_match_threshold": 0.42,
        "check_interval_sec": 0.5,
        "max_attempts_per_person": 100,
        "team_members": {
            "person1": {
                "name": "Person 1",
                "id": "T-001"
            },
            "person2": {
                "name": "Person 2",
                "id": "T-002"
            },
            "person3": {
                "name": "Person 3",
                "id": "T-003"
            },
            "person4": {
                "name": "Person 4",
                "id": "T-004"
            }
        }
    },
    "server": {
        "host": "0.0.0.0",
        "port": 5000,
        "debug": false
    },
    "camera": {
        "id": "PHONE-CAM-01"
    },
    "skeleton_action": {
        "model_path": "models/skeleton_lstm.pth",
        "sequence_length": 30,
        "postprocess": {
            "confidence_threshold": 0.65,
            "smoothing_alpha": 0.6
        }
    }
}